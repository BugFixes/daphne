BUGFIXES_BIND_ADDRESS=127.0.0.1:3000
BUGFIXES_DATABASE_URL=postgres://postgres:postgres@localhost:5432/bugfixes

BUGFIXES_FEATURE_FLAGS_PROVIDER=local
BUGFIXES_POLICY_PROVIDER=local
BUGFIXES_POLICY2_ENGINE_URL=https://api.policy2.net/run

# Optional local kill-switches:
# BUGFIXES_DISABLED_FEATURES=github,teams,codex

# Optional flags.gg runtime config.
# Requires building/running with the `flagsgg` cargo feature.
# BUGFIXES_FEATURE_FLAGS_PROVIDER=flagsgg
# BUGFIXES_FLAGSGG_PROJECT_ID=REPLACE_ME
# BUGFIXES_FLAGSGG_AGENT_ID=REPLACE_ME
# BUGFIXES_FLAGSGG_ENVIRONMENT_ID=REPLACE_ME
